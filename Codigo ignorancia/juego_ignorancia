#obtiene las preguntas de la base de datos
def preguntas(event):
	global seleccion
	cat = event.widget.get()
	#los espacios en blanco del combo de tkinter agregan llaves en el contenido
	#para eliminar ese problema recorremos el conjunto y cambiamos espacios
	#por un guion bajo _ para hacer la busqueda en la base de datos necesitamos ahora
	#reemplazar los guiones bajo _ por espacios en blanco
	cat=str(cat).replace("_"," ")
	seleccion=recupera_preguntas(cat)
	sel_preg()

